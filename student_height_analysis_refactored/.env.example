# 数据库配置
DB_DRIVER=sqlite
DB_NAME=data/student_height.db

# PostgreSQL配置（如果使用PostgreSQL，请取消下面的注释）
# DB_DRIVER=postgresql
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=student_height_db
# DB_USER=postgres
# DB_PASSWORD=your_password

# 连接池配置
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# 日志配置
LOG_LEVEL=INFO

# 应用配置
DEBUG=false
DEFAULT_DATA_COUNT=1000
RANDOM_SEED=42

# 图表配置
CHART_DPI=300
CHART_FORMAT=png
