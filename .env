# Application Configuration
APP_NAME=StudentHeightAnalysis
APP_ENV=development
APP_DEBUG=true

# Database Configuration
DB_TYPE=sqlite  # Options: sqlite, postgresql, mysql
DB_HOST=localhost
DB_PORT=5432
DB_NAME=student_height_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_SQLITE_PATH=./app.db

# Connection Pool Configuration
DB_POOL_MIN_CONN=5
DB_POOL_MAX_CONN=20
DB_POOL_MAX_OVERFLOW=10
DB_POOL_RECYCLE=3600

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
LOG_MAX_SIZE=10MB
LOG_BACKUP_COUNT=5

# Analysis Configuration
GRADE_ORDER=一年级,二年级,三年级,四年级,五年级,六年级
STANDARD_HEIGHTS_FILE=./config/standard_heights.json
